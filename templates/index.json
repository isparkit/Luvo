    "ss_testimonial_8_pPhRPq": {
      "type": "ss-testimonial-8",
      "blocks": {
        "slide_BbL6jE": {
          "type": "slide",
          "settings": {
            "stars_count": 5,
            "heading": "Value for money!",
            "text": "Var lidt skeptisk i starten pga den billigere pris end andre smart ringe på markedet, men er så glad for jeg gjore det, har ikke fortrudt på noget tidspunkt, så fedt at få mere indblik i ens søvn og stress faktor ! Og appen er nem at bruge for en der ikke er så god til elektronik genrelt.",
            "author_date": "Sofie H."
          }
        },
        "slide_hRprhN": {
          "type": "slide",
          "settings": {
            "stars_count": 5,
            "heading": "Uundværlig under træning!",
            "text": "Virkelig fed smart ring, som er nem at koble op med mobilen. Den er uundværlig for mig under min træning, og så var jeg glad for at der var flere farve muligheder.",
            "author_date": "Emma"
          }
        },
        "slide_4CxPtw": {
          "type": "slide",
          "settings": {
            "stars_count": 5,
            "heading": "God kundeservice, hurtigt og præcist",
            "text": "Jeg bestilte en ring der desværre ikke var den rigtige størrelse, men der var et størrelses Kit med, så jeg kunne finde den rigtige størrelse og så var der god kundeservice og jeg fik hurtigt byttet den til den rigtige størrelse, kan kun anbefale lunaring",
            "author_date": "Nick B."
          }
        },
        "slide_aFMrAD": {
          "type": "slide",
          "settings": {
            "stars_count": 5,
            "heading": "Mega fed!",
            "text": "Luvo Ring er bare mega fed! Stilrent design og smart - elsker at den tracker ens sundhed uden at det ser nørdet ud 👌",
            "author_date": "Hanan"
          }
        },
        "slide_AyiLXX": {
          "type": "slide",
          "settings": {
            "stars_count": 5,
            "heading": "Så glad for min Luvo Ring!",
            "text": "Jeg har brugt ringen lidt over en uge nu og er blevet rigtig glad for den. Det er især mega fedt at få et nærmere indblik i min søvn! Derudover er det et rigtig lækkert design:)",
            "author_date": "Stine R."
          }
        },
        "slide_3VQULw": {
          "type": "slide",
          "settings": {
            "stars_count": 5,
            "heading": "God værdi for pengene!",
            "text": "Har længe kigget efter et billigere alternativ til Auraring, og Luvo Ring lever helt op til forventningerne. Virkelig god kvalitet for pengene og fedt at appen er gratis at bruge! Også god service, at man får tilsendt en størrelsesguide inden køb, så man er sikker på at få den rigtige størrelse 🙌🏼",
            "author_date": "Anna D."
          }
        },
        "slide_wB4wJd": {
          "type": "slide",
          "settings": {
            "stars_count": 5,
            "heading": "Mega fedt koncept!",
            "text": "Mega fedt koncept. Ringen tracker alle de stats jeg har brug for, specielt når jeg løber. Den kobler også op til strava, hvilket er vigtigt da jeg samler alle mine sportslige aktiviteter derunder. Kæmpe fan her!",
            "author_date": "Muhammed H."
          }
        }
