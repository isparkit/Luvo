      "type": "collapsible-content",
      "blocks": {
        "collapsible_row_WJNxDa": {
          "type": "collapsible_row",
          "settings": {
            "heading": "Hvilke funktioner tilbyder Luvo Ring?",
            "icon": "none",
            "row_content": "<p>Luvo Ring måler din puls, søvn, aktivitetsniveau og kalorieforbrug. Den synkroniseres med vores app for at give dig en oversigt over din sundhed.</p>",
            "page": ""
          }
        },
        "collapsible_row_RcFRC4": {
          "type": "collapsible_row",
          "settings": {
            "heading": "Hvordan oplader jeg Luvo Ring, og hvor lang tid holder batteriet?",
            "icon": "none",
            "row_content": "<p>Luvo Ring oplades med en medfølgende magnetisk oplader. Batteriet holder i op til 7 dage på én opladning, afhængigt af brug.</p>",
            "page": ""
          }
        },
        "collapsible_row_tm4NiX": {
          "type": "collapsible_row",
          "settings": {
            "heading": "Kan Luvo Ring tåle vand?",
            "icon": "none",
            "row_content": "<p>Ja, Luvo Ring er vandafvisende og kan bruges i regnvejr og under træning. Dog anbefales det ikke at bruge den under svømning.</p>",
            "page": ""
          }
        },
        "collapsible_row_aGE9qc": {
          "type": "collapsible_row",
          "settings": {
            "heading": "Hvilke smartphones er kompatible med Luvo Ring?",
            "icon": "none",
            "row_content": "<p>Luvo Ring fungerer med både iOS og Android. Download vores app i App Store eller Google Play.</p>",
            "page": ""
          }
        }
      },
