    "product_reviews_2_VYY7Ci": {
      "type": "product-reviews-2",
      "blocks": {
        "item_xPbJdP": {
          "type": "item",
          "settings": {
            "stars_count": 5,
            "verified_text": "Bekræftet",
            "title": "",
            "text": "<p>\"Jeg har brugt Luvo Ring i en måned nu, og jeg er så imponeret over, hvor nemt det er at holde styr på min søvn og aktivitet.\"</p>",
            "author": "Sofie, København",
            "time": "3. November"
          }
        },
        "item_Kcbc76": {
          "type": "item",
          "settings": {
            "stars_count": 5,
            "verified_text": "Bekræftet",
            "title": "",
            "text": "<p>\"Jeg har tidligere brugt smartwatches, men blev træt af at skulle oplade dem hver dag. Luvo Ring er en gamechanger!\"</p>",
            "author": "Jonas, Aarhus",
            "time": "7. November"
          }
        },
        "item_DHgUYn": {
          "type": "item",
          "settings": {
            "stars_count": 5,
            "verified_text": "Bekræftet",
            "title": "",
            "text": "<p>\"Jeg elsker, hvordan Luvo Ring ser ud – det ligner et flot smykke, men er samtidig fyldt med teknologi. \"</p>",
            "author": "Maria, Odense",
            "time": "8. November"
          }
        },
        "item_LTUzmG": {
          "type": "item",
          "settings": {
            "stars_count": 5,
            "verified_text": "Bekræftet",
            "title": "",
            "text": "<p>\"Jeg var skeptisk i starten, men jeg må sige, at Luvo Ring har overrasket mig positivt.\"</p>",
            "author": "Mikkel, Aalborg",
            "time": "13. November"
          }
        }
      },
