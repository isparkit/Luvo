{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section class="luvo-works-section section-{{ section.id }}-padding color-{{ section.settings.color_scheme }}">
  <div class="page-width">
  <div class="luvo-works-container">

    <div class="luvo-works-heading-area">
    {% if section.settings.section_heading != blank %}
      <h2 class="h2 luvo-works-heading">{{ section.settings.section_heading }}</h2>
    {% endif %}

    {% if section.settings.section_subtext != blank %}
      <p class="luvo-works-subtext">{{ section.settings.section_subtext }}</p>
    {% endif %}
    </div>

    <!-- Tabs -->
    <div class="luvo-works-tabs">
      {% for block in section.blocks %}
        <button 
          class="luvo-works-tab {% if forloop.first %}active{% endif %}" 
          data-tab="tab-{{ forloop.index }}">
          {{ forloop.index | prepend: '0' }}. {{ block.settings.tab_title }}
        </button>
      {% endfor %}
    </div>

    <!-- Tab Content -->
    <div class="luvo-works-contents">
      {% for block in section.blocks %}
        <div id="tab-{{ forloop.index }}" class="luvo-works-content {% if forloop.first %}active{% endif %}">
          <div class="luvo-works-step-text">
            {% if block.settings.block_heading_one != blank %}
              <h6 class="block_heading">{{ block.settings.block_heading_one }}</h6>
            {% endif %}
            {% if block.settings.block_subtext_one != blank %}
              <h6 class="block_subtext">{{ block.settings.block_subtext_one }}</h6>
            {% endif %}
            {% if block.settings.block_heading_two != blank %}
              <h6 class="block_heading">{{ block.settings.block_heading_two }}</h6>
            {% endif %}
            {% if block.settings.block_subtext_two != blank %}
              <h6 class="block_subtext">{{ block.settings.block_subtext_two }}</h6>
            {% endif %}
            {% if block.settings.block_heading_three != blank %}
              <h6 class="block_heading">{{ block.settings.block_heading_three }}</h6>
            {% endif %}
            {% if block.settings.block_subtext_three != blank %}
              <h6 class="block_subtext">{{ block.settings.block_subtext_three }}</h67>
            {% endif %}
          </div>

          <div class="luvo-works-step-media">
            {% if block.settings.block_image != blank %}
              <img src="{{ block.settings.block_image | img_url: '800x' }}" alt="{{ block.settings.tab_title }}">
            {% endif %}
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
  </div>
</section>

{% schema %}
{
  "name": "Custom Luvo Works",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color Schema",
    },
    {
      "type": "text",
      "id": "section_heading",
      "label": "Section Heading",
      "default": "How Luvo Works"
    },
    {
      "type": "textarea",
      "id": "section_subtext",
      "label": "Section Subtext",
      "default": "Luvo combines cutting-edge sensors, seamless connectivity, and AI-powered insights—so you can focus on living, while it takes care of the tracking."
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step Block",
      "settings": [
        {
          "type": "text",
          "id": "tab_title",
          "label": "Tab Title",
          "default": "Wear the Ring"
        },
        {
          "type": "text",
          "id": "block_heading_one",
          "label": "Heading",
          "default": "What Happens"
        },
        {
          "type": "textarea",
          "id": "block_subtext_one",
          "label": "Subtext",
          "default": "Simply slip Luvo on your finger..."
        },
        {
          "type": "text",
          "id": "block_heading_two",
          "label": "Heading",
          "default": "What Happens"
        },
        {
          "type": "textarea",
          "id": "block_subtext_two",
          "label": "Subtext",
          "default": "Simply slip Luvo on your finger..."
        },
        {
          "type": "text",
          "id": "block_heading_three",
          "label": "Heading",
          "default": "What Happens"
        },
        {
          "type": "textarea",
          "id": "block_subtext_three",
          "label": "Subtext",
          "default": "Simply slip Luvo on your finger..."
        },
        {
          "type": "image_picker",
          "id": "block_image",
          "label": "Fallback Image"
        }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "Custom Luvo Works",
      "category": "Custom"
    }
  ]
}
{% endschema %}

<style>
.luvo-works-section .luvo-works-container .luvo-works-heading-area {
    max-width: 610px;
    margin: 0 auto;
    padding-bottom: 54px;
    text-align: center;
}
.luvo-works-section .luvo-works-container .luvo-works-heading-area h2 {
    font-family: 'Gordita-Bold';
    margin: 0;
    padding-bottom: 10px;
}
.luvo-works-section .luvo-works-container .luvo-works-heading-area p {
    font-family: 'Gordita-Regular';
    text-align: center;
    margin: 0;
}
.luvo-works-section .luvo-works-container .luvo-works-tabs {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 10px;
    padding-bottom: 34px;
}
.luvo-works-section .luvo-works-container .luvo-works-tabs .luvo-works-tab {
  background: transparent;
  font-size: 16px;
  font-family: 'Gordita-Semibold';
  border: none;
  padding: 10px 20px;
  border-radius: 20px;
  color: #AAAAAA;
  cursor: pointer;
  transition: 0.8s;
}
.luvo-works-section .luvo-works-container .luvo-works-tabs .luvo-works-tab.active {
  background: #000;
  color: #fff;
  box-shadow: 0 2px 6px rgba(0, 0, 0, 0.4), inset 0 1px 4px rgba(255, 255, 255, 0.2);
}
.luvo-works-section .luvo-works-container .luvo-works-contents {
  position: relative;
}
.luvo-works-section .luvo-works-container .luvo-works-contents .luvo-works-content {
  display: none;
  align-items: center;
  opacity: 0;
  transform: translateY(30px);
  transition: all 0.5s ease;
  border: 1px solid #1C1C1C;
  padding: 16px;
  border-radius: 34px;
  gap: 16px;
}
.luvo-works-section .luvo-works-container .luvo-works-contents .luvo-works-content.active {
    display: flex;
    opacity: 1;
    transform: translateY(0);
    align-items: self-end;
}
.luvo-works-section .luvo-works-container .luvo-works-contents .luvo-works-content .luvo-works-step-text {
  text-align: left;
}
.luvo-works-section .luvo-works-container .luvo-works-contents .luvo-works-content .luvo-works-step-text h6.block_heading {
    font-family: Gordita-Regular;
    line-height: 120%;
    color: #E3E3E3;
    margin: 0;
    padding-bottom: 12px;
}
.luvo-works-section .luvo-works-container .luvo-works-contents .luvo-works-content .luvo-works-step-text h6.block_subtext {
    font-family: Gordita-Semibold;
    line-height: 120%;
    color: #fff;
    margin: 0;
    padding-bottom: 34px;
}
.luvo-works-section .luvo-works-container .luvo-works-contents .luvo-works-content .luvo-works-step-media img {
  max-width: 100%;
  border-radius: 30px;
}

/* Slide animations */
.slide-in-up {
  animation: slideUp 0.9s ease forwards;
}
.slide-in-down {
  animation: slideDown 0.9s ease forwards;
}
@keyframes slideUp {
  from { opacity: 0; transform: translateY(50px); }
  to { opacity: 1; transform: translateY(0); }
}
@keyframes slideDown {
  from { opacity: 0; transform: translateY(-50px); }
  to { opacity: 1; transform: translateY(0); }
}

/* Mobile responsive */
@media(max-width:768px){
.luvo-works-section .luvo-works-container .luvo-works-tabs {
    overflow-x: auto;
    display: flex;
    flex-wrap: nowrap !important;
    white-space: nowrap;
    justify-content: flex-start;
}
 
  .luvo-works-section .luvo-works-container .luvo-works-contents .luvo-works-content .luvo-works-step-media img {
    width: 100%;
    border-radius: 30px;
    position: relative;
    min-height: 500px;
  }
  .luvo-works-section .luvo-works-container .luvo-works-contents .luvo-works-content .luvo-works-step-text {
    text-align: left;
    position: absolute;
    z-index: 1;
  }
  .luvo-works-section .luvo-works-container .luvo-works-tabs .luvo-works-tab{
    font-size: 14px;
  }
    .luvo-works-section .luvo-works-container .luvo-works-tabs::-webkit-scrollbar {
    display: none;
  }

  .luvo-works-content {
    grid-template-columns: 1fr;
    text-align: center;
  }
  .luvo-works-step-text {
    text-align: center;
  }
}

</style>

<script>
document.addEventListener("DOMContentLoaded", function() {
  const tabs = document.querySelectorAll(".luvo-works-tab");
  const contents = document.querySelectorAll(".luvo-works-content");
  let currentIndex = 0;

  tabs.forEach((tab, index) => {
    tab.addEventListener("click", function() {
      if (index === currentIndex) return;

      let targetId = this.getAttribute("data-tab");
      let targetContent = document.getElementById(targetId);

      tabs.forEach(t => t.classList.remove("active"));
      contents.forEach(c => {
        c.classList.remove("active", "slide-in-up", "slide-in-down");
      });

      this.classList.add("active");

      if (index > currentIndex) {
        targetContent.classList.add("slide-in-up");
      } else {
        targetContent.classList.add("slide-in-down");
      }

      targetContent.classList.add("active");

      currentIndex = index;
    });
  });
});
</script>
