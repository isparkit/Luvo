{{ 'section-main-page.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
  .page_app-info .custom-page-cls.page-width--narrow, .page_contact .custom-page-cls.page-width--narrow,
  .page_about-us .custom-page-cls.page-width--narrow{
      max-width: 100%;
  }
  .page_contact .custom-page-cls.page-width--narrow, .page_about-us .custom-page-cls.page-width--narrow {
    padding: 0;
  }
  .page_app-info .custom-page-cls h1.main-page-title, .page_contact .custom-page-cls h1.main-page-title,
  .page_about-us .custom-page-cls h1.main-page-title {
    text-align: center;
    background: #1C1C1C;
    color: #fff;
    font-size: clamp(28px, 2vw + 16px,54px);
    padding: 20px 0;
    font-family: 'Gordita-Bold';
    line-height: 1.2em;
    letter-spacing: 0;
  }
  .page_contact .custom-page-cls h1.main-page-title,
  .page_about-us .custom-page-cls h1.main-page-title {
    margin: 0;
  }
  .page_contact .custom-page-cls.page-width--narrow .rte {
    display: none;
  }
  .page_app-info .rte {
    max-width: 625px;
    margin: 0 auto;
    text-align: center;
  }
  .page_app-info .rte p {
    font-family: 'Gordita-Regular';
    font-weight: 400;
    line-height: 1.5em;
    letter-spacing: 0;
    font-size: clamp(16px, 0.38vw + 13px, 20px);
    color: rgba(var(--color-foreground));
  }
  @media screen and (max-width: 989px) {
    .page_app-info .custom-page-cls.page-width--narrow {
      padding: 0;
    }
   .page_app-info .custom-page-cls .rte {
      padding: 0 2rem 30px;
    }
  }
{%- endstyle -%}

<div class="custom-page-cls page-width page-width--narrow section-{{ section.id }}-padding">
  <h1 class="main-page-title page-title h0{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}">
    {{ page.title | escape }}
  </h1>
  <div class="rte{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
    {{ page.content }}
  </div>
</div>

{% schema %}
{
  "name": "t:sections.main-page.name",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    }
  ]
}
{% endschema %}