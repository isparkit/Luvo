{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section class="faq-accordion-section color-{{ section.settings.color_scheme }} section-{{ section.id }}-padding" id="faq-accordion-{{ section.id }}">
  <div class="page-width">
    <div class="faq-accordion-heading-area">
    {% if section.settings.heading %}<h2 class="faq-title">{{ section.settings.heading }}</h2>{% endif %}
      {% if section.settings.subheading != blank %}
        <p class="faq-subtitle">{{ section.settings.subheading }}</p>
      {% endif %}
    </div>
  <div class="faq-container">
    <div class="faq-left">
      {% if section.settings.faq_image %}
        <img src="{{ section.settings.faq_image | img_url: '600x' }}" alt="FAQ Image">
      {% endif %}
    </div>
    <div class="faq-right">

      <div class="faq-items">
        {% for block in section.blocks %}
          <div class="faq-item" id="faq-{{ section.id }}-{{ forloop.index }}">
            <button class="faq-question" aria-expanded="false">
              {{ block.settings.question }}
              <span class="faq-icon"></span>
            </button>
            <div class="faq-answer">
              <p>{{ block.settings.answer }}</p>
            </div>
          </div>
        {% endfor %}
      </div>
    </div>
  </div>
  </div>
</section>

{% schema %}
{
  "name": "Custom FAQ Accordion",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color Schema",
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "Everything You Need to Know About Luvo"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Section Subheading",
      "default": "From battery life to compatibility, here are answers to the most common questions about Luvo Smart Ring."
    },
    {
      "type": "image_picker",
      "id": "faq_image",
      "label": "Left Side Image"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "FAQ",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question"
        },
        {
          "type": "textarea",
          "id": "answer",
          "label": "Answer"
        }
      ]
    }
  ],
  "max_blocks": 10,
  "presets": [
    {
      "name": "Custom FAQ Accordion",
      "category": "Custom"
    }
  ]
}
{% endschema %}

<style>

.faq-accordion-section .faq-accordion-heading-area {
    text-align: center;
    margin: 0 auto;
    max-width: 613px;
}
.faq-accordion-section .faq-accordion-heading-area h2 {
    font-family: 'Gordita-Bold';
    font-weight: 700;
    margin: 0;
    line-height: 1.2em;
    padding-bottom: 8px;
}
.faq-accordion-section .faq-accordion-heading-area p {
    font-family: 'Gordita-Regular';
    font-weight: 400;
    margin: 0;
    line-height: 1.2em;
    padding-bottom: 54px;
}

 .faq-accordion-section .faq-container {
  display: flex;
  flex-wrap: wrap;
  gap: 16px;
  margin: 0 auto;
  align-items: flex-start;
} 
.faq-left img {
    max-width: 462px;
    min-height: 422px;
    border-radius: 16px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.3);
}
.faq-right {
  flex: 1;
  min-width: 300px;
}
.faq-accordion-section .faq-container .faq-right .faq-items .faq-item {
    border: 1px solid #393939;
    margin-bottom: 10px;
    padding: 16px;
    border-radius: 12px;
}
.faq-accordion-section .faq-container .faq-right .faq-items .faq-item .faq-question {
    font-family: 'Gordita-Medium';
    font-weight: 500;
    width: 100%;
    background: none;
    color: #E3E3E3;
    display: flex;
    justify-content: space-between;
    border: 0;
    padding-left: 0;
    padding-right: 0;
    font-size: 16px;
    line-height: 1.2em;
    letter-spacing: 0;
    cursor: pointer;
}
{% comment %} .faq-question {
  font-family: 'Gordita-Medium';
  font-weight: 500; 
  width: 100%;
  background: none;
  border: none;
  text-align: left;
  padding: 15px;
  font-size: 16px;
  color: #fff;
  display: flex;
  justify-content: space-between;
  align-items: center;
} {% endcomment %}
.faq-accordion-section .faq-container .faq-right .faq-items .faq-item .faq-answer p {
    margin: 0;
    font-family: 'Gordita-Medium';
    font-weight: 500;
    line-height: 1.3em;
    letter-spacing: 0;
    padding-top: 10px;
}
.faq-answer {
  display: none;
  opacity: 0.9;
}
.faq-question.active + .faq-answer {
  display: block;
}
.faq-icon {
  transition: transform 0.3s ease;
}
.faq-question .faq-icon::before {
  content: "+";
}
.faq-question.active .faq-icon::before {
  content: "-";
}
</style>

