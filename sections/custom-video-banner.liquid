<section class="color-{{ section.settings.color_scheme }} video-hero">
  <div class="video-hero__bg">
    {% if section.settings.bg_video != blank %}
      {{ section.settings.bg_video | video_tag: autoplay: true, loop: true, muted: true, playsinline: true, class: 'video-hero__video' }}
    {% endif %}
  </div>

  <div class="page-width">
  <div class="video-hero__content">
    <div class="video-text-area">
    {% if section.settings.heading != blank %}
      <h1 class="video-hero__heading">{{ section.settings.heading }}</h1>
    {% endif %}
    {% if section.settings.subtext != blank %}
      <h6 class="video-hero__subtext">{{ section.settings.subtext }}</h6>
    {% endif %}
    {% if section.settings.btn_text != blank %}
      <a href="{{ section.settings.btn_link }}" class="video-hero__btn">
        {{ section.settings.btn_text }}
      </a>
    {% endif %}
    </div>
  </div>
  </div>
</section>

<style>
  .video-hero {
    position: relative;
    width: 100%;
    min-height: 100vh;
    overflow: hidden;
    color: #fff;
  }

  .video-hero__video {
    width: 100%;
    height: 700px;
    object-fit: cover;
  }

  .video-hero__content {
    position: absolute;
    bottom: 30px;
    left: 50px;
  }

  .video-text-area {
    text-align: left;
    max-width: 430px;
  }

  .video-hero__content.page-width {
    position: absolute;
    max-width: 600px;
    bottom: 0;
}
  .video-hero__heading {
    font-family: 'Gordita-Bold';
    font-size: 54px;
    font-weight: 700;
    margin: 0;
  }

  .video-hero__subtext {
    font-family: 'Gordita-Medium';
    font-weight: 500;
    line-height: 1.5em;
    letter-spacing: 0;
    margin: 0;
  }

  .video-hero__btn {
    display: inline-block;
    background: #fff;
    color: #000;
    padding: 10px 25px;
    border-radius: 25px;
    font-weight: 500;
    text-decoration: none;
    transition: 0.3s;
  }

  .video-hero__btn:hover {
    background: #000;
    color: #fff;
  }

  /* Mobile Responsive */
  @media screen and (max-width: 768px) {
    .video-hero__heading {
      font-size: 26px;
    }
    .video-hero__subtext {
      font-size: 14px;
    }
    .video-hero__btn {
      padding: 8px 20px;
      font-size: 14px;
    }
  }
</style>

{% schema %}
{
  "name": "Custom Video Banner",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color Schema",
    },
    {
      "type": "video",
      "id": "bg_video",
      "label": "Background Video"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Luvo The Future on Your Finger"
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtext",
      "default": "Experience the perfect blend of technology and elegance. Track health, stay connected, and express your style all with one smart ring."
    },
    {
      "type": "text",
      "id": "btn_text",
      "label": "Button Text",
      "default": "Discover Luvo Ring II"
    },
    {
      "type": "url",
      "id": "btn_link",
      "label": "Button Link",
      "default": "/collections/all"
    }
  ],
  "presets": [
    {
      "name": "Custom Video Banner"
    }
  ]
}
{% endschema %}
