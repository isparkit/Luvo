{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.3 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.3 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
        padding-top: {{ section.settings.padding_top }}px;
        padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

.why-choose-luvo-section {
    text-align: center;
}
.why-choose-luvo-section h2 {
    font-family: 'Gordita-Bold';
    font-weight: 700;
    line-height: 1.2em;
    letter-spacing: 0;
    margin: 0 0 8px;
}
.why-choose-luvo-section .subtitle {
    font-family: 'Gordita-Regular';
    font-weight: 400;
    line-height: 1.2em;
    letter-spacing: 0;
    color: rgba(var(--color-foreground), 0.75);
    max-width: 462px;
    margin: 0 auto;
}
.why-choose-luvo-section .luvo-info .info-content h6{
    font-family: 'Gordita-Bold';
    font-weight: 700;
    line-height: 1.5em;
    letter-spacing: 0;
    margin: 0 0 4px;
    color: rgba(var(--color-foreground));
}
.why-choose-luvo-section .luvo-info .info-content p {
    font-family: 'Gordita-Regular';
    font-weight: 400;
    line-height: 1.2em;
    letter-spacing: 0;
    color: rgba(var(--color-foreground), 0.75);
    max-width: 264px;
    margin: 0 auto;
}
.why-choose-luvo-section .luvo-info .info-block:nth-of-type(1) .info-content p {
    max-width: 200px;
}
.why-choose-luvo-section .luvo-info {
    margin: auto;
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    grid-template-rows: auto auto;
    align-items: center;
    margin-top: 64px;
}
.why-choose-luvo-section .luvo-info .ring-image {
    order: 2;
    grid-column: 2;
    grid-row: 1 / 3;
}
.why-choose-luvo-section .info-block {
    position: relative;
    z-index: 1;
}
.why-choose-luvo-section .info-block:nth-of-type(1) .info-content {
    position: absolute;
    left: 102px;
    top: -35px;
}
.why-choose-luvo-section .info-block:nth-of-type(2) .info-content {
    position: absolute;
    bottom: -54px;
    left: -76px;
}
.why-choose-luvo-section .info-block:nth-of-type(3) .info-content {
    position: absolute;
    top: -24px;
    left: 80px;
}
.why-choose-luvo-section .info-block:nth-of-type(4) .info-content  {
    position: absolute;
    top: 47px;
    left: -124px;
}
.why-choose-luvo-section .info-block:nth-of-type(1) {
    order: 1;
    grid-column: 1;
    grid-row: 1;
}
.why-choose-luvo-section .info-block:nth-of-type(2) {
    order: 3;
    grid-column: 3;
    grid-row: 1;
    align-self: flex-start;
}
.why-choose-luvo-section .info-block:nth-of-type(3) {
    order: 4;
    grid-column: 1;
    grid-row: 2;
    align-self: flex-end;
}
.why-choose-luvo-section .info-block:nth-of-type(4) {
    order: 5;
    grid-column: 3;
    grid-row: 2;
}
.why-choose-luvo-section .info-block:nth-of-type(2) .info-content, .why-choose-luvo-section .info-block:nth-of-type(4) .info-content {
    margin-right: 0;
    margin-left: auto;
}
.why-choose-luvo-section .info-block:nth-of-type(2) h6::after,  .why-choose-luvo-section .info-block:nth-of-type(4) h6::after {
    left: -15px;
}
 .why-choose-luvo-section .info-block:nth-of-type(1)::after {
    content: "";
    position: absolute;
    width: 239px;
    min-height: 57px;
    height: auto;
    background: url('https://cdn.shopify.com/s/files/1/0599/3044/3889/files/Group_1.png?v=1756883689') no-repeat center / 100%;
    top: 56px;
    right: -144px;
}
 .why-choose-luvo-section .info-block:nth-of-type(2)::after {
    content: "";
    position: absolute;
    width: 337px;
    min-height: 57px;
    background: url('https://cdn.shopify.com/s/files/1/0599/3044/3889/files/Group_2.png?v=1756883795') no-repeat center / 100%;
    top: 56px;
    right: 295px;
}
 .why-choose-luvo-section .info-block:nth-of-type(3)::after {
    content: "";
    position: absolute;
    width: 224px;
    min-height: 57px;
    background: url('https://cdn.shopify.com/s/files/1/0599/3044/3889/files/Group_3.png?v=1756883795') no-repeat center / 100%;
    top: -85px;
    left: 205px;
}
 .why-choose-luvo-section .info-block:nth-of-type(4)::after {
    content: "";
    position: absolute;
    width: 337px;
    min-height: 57px;
    background: url('https://cdn.shopify.com/s/files/1/0599/3044/3889/files/Group_4.png?v=1756883795') no-repeat center / 100%;
    top: -17px;
    right: 327px;
}
  @media screen and (max-width: 1200px) {
    .why-choose-luvo-section .info-block:nth-of-type(1) .info-content, .why-choose-luvo-section .info-block:nth-of-type(3) .info-content, .why-choose-luvo-section .info-block:nth-of-type(2) .info-content, .why-choose-luvo-section .info-block:nth-of-type(4) .info-content {
        left: 0;
        width: 100%;
    }
    .why-choose-luvo-section .info-block:nth-of-type(2) .info-content {
        top: 0;
        left: -50px;
    }
    .why-choose-luvo-section .info-block:nth-of-type(2)::after {
        top: 70px;
        right: 317px;
        width: 100%;
     }
     .why-choose-luvo-section .info-block:nth-of-type(3)::after {
        top: -85px;
        left: 131px;
        width: 100%;
     }
     .why-choose-luvo-section .info-block:nth-of-type(4)::after {
        width: 100%;
        top: -17px;
        right: 351px;
     }
  }
  @media screen and (max-width: 989px) {
    .why-choose-luvo-section .luvo-info {
        grid-template-columns: 1fr;
    }
    .why-choose-luvo-section .luvo-info .ring-image {
        order: 3;
        grid-column: 1;
        grid-row: 3;
        margin: 10px auto;
        width: 70vw;
    }
    .why-choose-luvo-section .info-block:nth-of-type(1) {
        order: 1;
        grid-column: 1;
        grid-row: 1;
    }
    .why-choose-luvo-section .info-block:nth-of-type(2) {
        text-align: right;
        margin-top: -20px;
        order: 2;
        grid-column: 1;
        grid-row: 2;
    }
    .why-choose-luvo-section .info-block:nth-of-type(3) {
        order: 5;
        grid-column: 1;
        grid-row: 5;
    }
    .why-choose-luvo-section .info-block:nth-of-type(4) {
        order: 4;
        grid-column: 1;
        grid-row: 4;
    }
    .why-choose-luvo-section .luvo-info .info-content p, .why-choose-luvo-section .luvo-info .info-block:nth-of-type(1) .info-content p {
        max-width: 100%;
    }
    .why-choose-luvo-section .info-block:nth-of-type(1) .info-content, .why-choose-luvo-section .info-block:nth-of-type(3) .info-content, .why-choose-luvo-section .info-block:nth-of-type(2) .info-content, .why-choose-luvo-section .info-block:nth-of-type(4) .info-content {
        position: relative;
        max-width: 240px;
    }
    .why-choose-luvo-section .info-block:nth-of-type(1)::after {
        content: "";
        position: absolute;
        background: url('https://cdn.shopify.com/s/files/1/0599/3044/3889/files/Mobile_line_1.png?v=1756900258') no-repeat center 100%;
        width: 100px;
        height: 245px;
        top: 2px;
        left: 101px;
    }
    .why-choose-luvo-section .info-block:nth-of-type(2)::after {
        background: url(https://cdn.shopify.com/s/files/1/0599/3044/3889/files/Mobile_line_2.png?v=1756900258) no-repeat center 100%;
        top: 57px;
        right: 0;
        width: 100%;
    }
    .why-choose-luvo-section .info-block:nth-of-type(3)::after {
        top: -69px;
        left: 57px;
        width: 92px;
        min-height: 189px;
        background: url(https://cdn.shopify.com/s/files/1/0599/3044/3889/files/Mobile_line_3.png?v=1756900258) no-repeat center / 100%;
    }
    .why-choose-luvo-section .info-block:nth-of-type(4)::after {
        background: url(https://cdn.shopify.com/s/files/1/0599/3044/3889/files/Mobile_line_4.png?v=1756900258) no-repeat center / 100%;
        width: 48px;
        top: -98px;
        right: 122px;
        min-height: 105px;
    }
    .why-choose-luvo-section .info-block:nth-of-type(3) .info-content {
        margin-left: 0;
        margin-right: auto;
    }
  }
{%- endstyle -%}

<div class="why-choose-luvo-section color-{{ section.settings.color_scheme }} section-{{ section.id }}-padding">
  <div class="page-width">
    <h2>{{ section.settings.heading }}</h2>
    <p class="subtitle">{{ section.settings.subtext }}</p>

    <div class="luvo-info">
      {% if section.settings.ring_image != blank %}
        <img src="{{ section.settings.ring_image | image_url: width: 494 }}" alt="Luvo Smart Ring" class="ring-image">
      {% endif %}

      {% for block in section.blocks %}
        <div class="info-block">
          <div class="info-content">
            <h6>{{ block.settings.title }}</h6>
            <p>{{ block.settings.description }}</p>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Homepage Product Info",
  "tag": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subheading"
    },
    {
      "type": "image_picker",
      "id": "ring_image",
      "label": "Center Ring Image"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "info",
      "name": "Info Block",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Feature title"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Feature description"
        }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "Homepage Product Info",
      "category": "Custom"
    }
  ]
}
{% endschema %}
